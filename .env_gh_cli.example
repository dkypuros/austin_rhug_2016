# Example environment for GitHub CLI (`gh`).
# Copy this file to `.env_gh_cli`, fill in real values, then keep `.env_gh_cli` private.
#
#   cp .env_gh_cli.example .env_gh_cli
#   chmod 600 .env_gh_cli
#
# Do NOT commit `.env_gh_cli`; it is ignored by `.gitignore`.

# GitHub host. Use github.com unless you are using GitHub Enterprise.
GH_HOST=github.com

# Your GitHub username / owner.
GH_REPO_OWNER=dkypuros

# Set this to the repository you want to work with, e.g. austin_rhug_2016.
GH_REPO=austin_rhug_2016

# Optional: GitHub CLI can use GH_TOKEN or GITHUB_TOKEN for non-interactive auth.
# Prefer `gh auth login` for local interactive use.
# Create a fine-grained token only if automation requires it, then paste it into `.env_gh_cli` only.
# GH_TOKEN=REPLACE_WITH_GITHUB_TOKEN
# GITHUB_TOKEN=REPLACE_WITH_GITHUB_TOKEN

# Optional defaults for issue/PR creation examples.
GH_DEFAULT_BRANCH=main
GH_ISSUE_LABEL=task
