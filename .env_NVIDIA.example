# Example NVIDIA API environment settings.
# Copy to `.env_NVIDIA`, fill in real values, then keep `.env_NVIDIA` private.
#
#   cp .env_NVIDIA.example .env_NVIDIA
#   chmod 600 .env_NVIDIA
#   set -a; source .env_NVIDIA; set +a

# NVIDIA API Catalog / NIM commonly uses NVIDIA_API_KEY.
NVIDIA_API_KEY="REPLACE_WITH_NVIDIA_API_KEY"

# Optional aliases used by some NVIDIA/NGC tooling.
NGC_API_KEY="$NVIDIA_API_KEY"
NVAPI_KEY="$NVIDIA_API_KEY"

# Optional default NVIDIA API endpoint for OpenAI-compatible NIM calls.
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"

# Example usage:
# curl -s "$NVIDIA_BASE_URL/models" -H "Authorization: Bearer $NVIDIA_API_KEY"
