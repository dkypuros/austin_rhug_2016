# Example OpenShift/RHDP lab environment settings.
# Copy to `.env_openshift_lab`, replace placeholders, and keep the real file private.
#
#   cp .env_openshift_lab.example .env_openshift_lab
#   chmod 600 .env_openshift_lab
#   set -a; source .env_openshift_lab; set +a

# Lab identity
OPENSHIFT_LAB_NAME="Composer AI"
OPENSHIFT_LAB_ID="REPLACE_WITH_LAB_ID"
OPENSHIFT_CLUSTER_NAME="REPLACE_WITH_CLUSTER_NAME"
OPENSHIFT_BASE_DOMAIN="REPLACE_WITH_BASE_DOMAIN"

# Access URLs
OPENSHIFT_CONSOLE_URL="https://console-openshift-console.apps.REPLACE_WITH_CLUSTER_APPS_DOMAIN"
OPENSHIFT_API_URL="https://api.REPLACE_WITH_CLUSTER_DOMAIN:6443"
OPENSHIFT_GITOPS_ARGOCD_URL="https://openshift-gitops-server-openshift-gitops.apps.REPLACE_WITH_CLUSTER_APPS_DOMAIN"
OPENSHIFT_OC_CLIENT_URL="https://mirror.openshift.com/pub/openshift-v4/clients/ocp/REPLACE_WITH_VERSION/openshift-client-linux-REPLACE_WITH_VERSION.tar.gz"

# Optional CA bundle path for verified TLS with oc/curl.
OPENSHIFT_CA_CERT="REPLACE_WITH_CA_CERT_PATH_IF_NEEDED"

# Auth provider
OPENSHIFT_AUTH_PROVIDER="htpasswd"

# Cluster admin credentials - fill only in the real .env file.
OPENSHIFT_ADMIN_USER="admin"
OPENSHIFT_ADMIN_PASSWORD="REPLACE_WITH_ADMIN_PASSWORD"

# Normal user credentials - fill only in the real .env file.
OPENSHIFT_USER="user1"
OPENSHIFT_USER_PASSWORD="REPLACE_WITH_USER_PASSWORD"

# Lifecycle timestamps from RHDP. Use UTC ISO-8601 values.
OPENSHIFT_STOP_AT_UTC="REPLACE_WITH_STOP_TIMESTAMP"
OPENSHIFT_EXPIRE_AT_UTC="REPLACE_WITH_EXPIRE_TIMESTAMP"

# Handy derived command examples:
# oc login "$OPENSHIFT_API_URL" -u "$OPENSHIFT_ADMIN_USER" --certificate-authority "$OPENSHIFT_CA_CERT"
# oc login "$OPENSHIFT_API_URL" -u "$OPENSHIFT_USER" --certificate-authority "$OPENSHIFT_CA_CERT"
